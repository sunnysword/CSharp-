<UserControl x:Class="Handler.View.MainUnits.Unit_MainBtns_1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Handler.View.MainUnits"
             xmlns:Lan="clr-namespace:LanguageControlBase.Wpf;assembly=LanguageControlBase"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="500" MaxWidth="500" Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>

        </Grid.RowDefinitions>
        <!--<CheckBox x:Name="chb_RobotSelect"  Content="机械手联动" Margin="20,5"></CheckBox>-->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" MinHeight="50"/>
                <RowDefinition Height="1*" MinHeight="50"/>
                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Lan:LanButton x:Name="btn_ResMachine" LanContent="机器复位"  Grid.Row="0" Grid.Column="0" Background="Yellow"  FontSize="15"  Margin="10,5" MaxHeight="60" MaxWidth="140"   Click="Btn_ResMachine_Click"/>
            <Lan:LanButton x:Name="btn_ClearErr" LanContent="报警解除" Grid.Row="0" Grid.Column="1" Background="DodgerBlue"  FontSize="15"   Margin="10,5" MaxHeight="60" MaxWidth="140"  Click="Btn_ClearErr_Click"/>
            <Lan:LanButton x:Name="btn_OpenSafeDoor" LanContent="开启安全门" Grid.Row="0" Grid.Column="2" Background="LightBlue"  FontSize="15"  Margin="10,5"  MaxHeight="60" MaxWidth="140"  Click="btn_OpenSafeDoor_Click" Visibility="Collapsed"/>
            <Lan:LanButton x:Name="btn_Start" LanContent="启动" Grid.Row="1" Grid.Column="0" Background="LimeGreen"  FontSize="15"   Margin="10,5" MaxHeight="60" MaxWidth="140"  Click="Btn_Start_Click"/>
            <Lan:LanButton x:Name="btn_Pause" LanContent="暂停" Grid.Row="1" Grid.Column="1" Background="DarkTurquoise"  FontSize="15"  Margin="10,5" MaxHeight="60" MaxWidth="140"  Click="Btn_Pause_Click" />
            <Lan:LanButton x:Name="btn_Lamp" LanContent="开启照明" Grid.Row="1" Grid.Column="2"  FontSize="15" Margin="10,5"  MaxHeight="60" MaxWidth="140"  Click="btn_Lamp_Click"  />

            <StackPanel Orientation="Vertical" VerticalAlignment="Top" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
                <Lan:LanButton x:Name="btn_Stop"  MinHeight="50" Content="停  止"  Background="Red"  Margin="20,20" MaxWidth="280" MaxHeight="60" FontSize="25" FontFamily="新宋体"  Click="Btn_Stop_Click"/>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Row="1"  Grid.ColumnSpan="1" Grid.Column="0" Content="清料模式" Name="chb_IsLClearMode" Click="Chb_IsLClearMode_Click"></CheckBox>
                    <CheckBox Grid.Row="1"  Grid.ColumnSpan="2" Grid.Column="1" Content="重投模式" Name="chb_IsLReProduce" Click="chb_IsLReProduce_Click"></CheckBox>
                </Grid>
                    <StackPanel Orientation="Horizontal">
                    <Label  Content="从PCB料盘第几个之后清料"  ></Label>
                    <TextBox x:Name="ClearCount" Width="100"></TextBox>
                </StackPanel>

            </StackPanel>


        </Grid>


    </Grid>
</UserControl>
