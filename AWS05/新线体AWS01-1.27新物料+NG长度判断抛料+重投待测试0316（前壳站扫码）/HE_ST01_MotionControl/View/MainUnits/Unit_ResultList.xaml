        <!--
            半成品测试
        -->
        <DataGrid
            Margin="5"
            
            Name="lv_Sit2Station"
            Grid.Column="0"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="180">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal" x:Name="stackPanel2">
                            <TextBlock Text="半成品测试"/>
                            <TextBlock 
                                Text="{Binding TotalResult2, Converter={StaticResource Resource_ProductResultToString}}"
       Background="{Binding TotalResult2, Converter={StaticResource Resource_ProductResultToColor}}"
                    Margin="10,0,0,0"/>
                        </StackPanel>
                    </DataGridTemplateColumn.Header>

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Background="{Binding bdBrush}"
                                Foreground="Black"
                                Text="{Binding Name}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="80" Header="测试值">
