<UserControl x:Class="Handler.View.MainUnits.Unit_AviewTitle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Handler.View.MainUnits"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="260">
    <Grid>
        <Border   BorderThickness="1" BorderBrush="White"  Grid.Row="0" Grid.Column="0"  CornerRadius="2" >
            <Border BorderBrush="#4FFFFFFF"  BorderThickness="2"  Grid.Row="0" Grid.Column="0"   Margin="4" CornerRadius="5" >
                <Grid Margin="10,4">
                    <Grid.RowDefinitions>
                        <RowDefinition/>

                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Image Source="/Resources/aviewtitle.jpg" Stretch="None" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Left"  Margin="10,0,0,0" VerticalAlignment="Center" />
                    <TextBlock Text="Aview" Margin="20,0" FontSize="35"  FontStyle="Italic" FontWeight="Bold" Grid.Column="1" Grid.Row="0" VerticalAlignment="Center"/>
                    <!--<TextBlock Name="tb_WorkMode" Text="在线" Margin="0,10" FontSize="25" Background="Green"  FontStyle="Italic" FontWeight="Bold" Grid.Column="2" Grid.Row="0" VerticalAlignment="Center"/>-->

                </Grid>
            </Border>

        </Border>

    </Grid>
</UserControl>
