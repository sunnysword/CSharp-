<UserControl x:Class="Handler.View.MainUnits.Unit_ProductInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Handler.View.MainUnits"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="220">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontSize="15"
            Text="生产总数：" />
        <TextBox
            x:Name="tb_TotalProductNum"
            Grid.Row="0"
            Grid.Column="1"
            MinWidth="60"
            MaxHeight="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Left"
            VerticalContentAlignment="Bottom"
            IsReadOnly="True"
            Background="Transparent"
            BorderThickness="0"
            Text="0" />
        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            Margin="10,0,0,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontSize="15"
            Text="OK：" />
        <TextBox
            x:Name="tb_OkProductNum"
            Grid.Row="1"
            Grid.Column="1"
            MinWidth="60"
            MaxHeight="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Left"
            VerticalContentAlignment="Bottom"
            Background="Transparent"
            Foreground="Green"
            BorderThickness="0"
            IsReadOnly="True"
            Text="0000000" />
        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            Margin="10,0,0,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontSize="15"
            Text="NG：" />
        <TextBox
            x:Name="tb_NgProductNum"
            Grid.Row="2"
            Grid.Column="1"
            MinWidth="60"
            MaxHeight="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Left"
            VerticalContentAlignment="Bottom"
            Background="Transparent"
            Foreground="Red"
            BorderThickness="0"
            
            IsReadOnly="True"
            Text="0" />

        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontSize="15"
            Text="良率：" />
        <TextBox
            x:Name="tb_OKPercent"
            Grid.Row="3"
            Grid.Column="1"
            MinWidth="60"
            MaxHeight="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Left"
            VerticalContentAlignment="Bottom"
            IsReadOnly="True"
            Foreground="Black"
            Background="Transparent"
            BorderThickness="0"
            Text="0" />
        <!--<Button
            Name="btn_ClearProduct"
            Grid.Row="2"
            Grid.Column="5"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Background="Red"
            Click="Btn_ClearProduct_Click"
            Content="  Clear  "
            Cursor="Hand"
            FontSize="15" />

        <Button
            Name="btn_NgProduct"
            Grid.Row="2"
            Grid.Column="3"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Background="LightBlue"
            Click="Btn_NgProduct_Click"
            Content="Ng Detail"
            Cursor="Hand"
            FontSize="15" />-->

        <Button x:Name="btnClear"
                    Click="btnClear_Click"
                 Grid.Row="3" Grid.Column="2"
                Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,5,0" >
            <Button.Content>
                <TextBlock Text="生产清零"  Foreground="Blue">
                    <TextBlock.TextDecorations>
                        <TextDecoration>
                            <TextDecoration.Pen>
                                <Pen Thickness="1" Brush="Blue">
                                </Pen>
                            </TextDecoration.Pen>
                        </TextDecoration>
                    </TextBlock.TextDecorations>
                </TextBlock>
            </Button.Content>
        </Button>

        <TextBlock
            Grid.Row="4"
            Grid.Column="0"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            FontSize="15"
            Text="UPH：" />
        <TextBox
            x:Name="tb_UPH"
            Grid.Row="4"
            Grid.Column="1"
            MinWidth="60"
            MaxHeight="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Left"
            VerticalContentAlignment="Bottom"
            IsReadOnly="True"
            Background="Transparent"
            BorderThickness="0"
            Text="0" />
        <!--<TextBlock
                Grid.Row="0"
                Grid.Column="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                FontSize="15"
                Text="NG TOP3：" />
        <TextBox
            x:Name="tb_NGTOP"
            Grid.Row="1"
            Grid.Column="2"
            Grid.RowSpan="2"
            Grid.ColumnSpan="2"
            MinWidth="100"
            Height="50"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            IsReadOnly="True"
            Background="Transparent"
            BorderThickness="0"
            Text="" />-->
        <!--<Button x:Name="btnDetail" 
                    Click="btnDetail_Click"
                Grid.Row="2" Grid.Column="2"
                    Background="Transparent" BorderThickness="0" Cursor="Hand" Panel.ZIndex="10">
            <Button.Content>
                <TextBlock Text="生产详细" Foreground="Blue">
                    <TextBlock.TextDecorations>
                        <TextDecoration>
                            <TextDecoration.Pen>
                                <Pen Thickness="1" Brush="Blue">
                                </Pen>
                            </TextDecoration.Pen>
                        </TextDecoration>
                    </TextBlock.TextDecorations>
                </TextBlock>
            </Button.Content>
        </Button>-->
    </Grid>


</UserControl>
