<UserControl x:Class="Handler.View.MainUnits.Unit_TypeNameAndMode"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Handler.View.MainUnits"
             mc:Ignorable="d" 
              d:DesignHeight="100" d:DesignWidth="240" FontSize="20">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="5"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="5"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="5"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="1" Grid.Column="0" Text="用户: " HorizontalAlignment="Right" FontWeight="Bold" FontSize="15"></TextBlock>
        <TextBlock Name="tb_LoginUsers" Grid.Row="1" Grid.Column="1"  FontSize="15" Text="Normal | 12345"></TextBlock>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="机种: " HorizontalAlignment="Right" FontWeight="Bold" FontSize="15"></TextBlock>
        <TextBlock Name="tb_TypeName" Grid.Row="3" Grid.Column="1"   FontSize="15" VerticalAlignment="Center" Text="111222"></TextBlock>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="模式: " HorizontalAlignment="Right" FontWeight="Bold" FontSize="15"></TextBlock>
        <TextBlock Name="tb_Mode" Grid.Row="5" Grid.Column="1"    FontSize="15" VerticalAlignment="Center" Text="111222"></TextBlock>


        <!--<TextBlock Grid.Row="7" Grid.Column="0" Text="工单: " HorizontalAlignment="Right" FontStyle="Italic" FontWeight="Bold" FontSize="15"></TextBlock>-->
        <!--<TextBlock Name="tb_WorkOrder" Grid.Row="7" Grid.Column="1"    FontSize="15" Background="AliceBlue" VerticalAlignment="Center" Text="111222"></TextBlock>-->

    </Grid>
</UserControl>
