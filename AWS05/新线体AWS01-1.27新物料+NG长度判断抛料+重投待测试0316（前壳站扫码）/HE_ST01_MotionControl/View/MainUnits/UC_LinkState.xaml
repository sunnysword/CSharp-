<UserControl x:Class="Handler.View.MainUnits.UC_LinkState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Handler.View.MainUnits"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="600"
             FontSize="14">
    <StackPanel Orientation="Vertical">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
            <TextBlock Text="MES: " Margin="10,2,2,2"></TextBlock>
            <TextBlock Name="tb_MesIsUse"  Background="Red" Margin="2"></TextBlock>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
            <TextBlock Text="RFID: " Margin="10,0,0,0"></TextBlock>
            <TextBlock Name="tb_IsUseRFID"  Background="Red" Margin="2"></TextBlock>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
            <TextBlock Text="壳体扫码: " Margin="10,2,2,2"></TextBlock>
            <TextBlock Name="tb_1"   Margin="2"></TextBlock>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
            <TextBlock Text="PCB扫码: " Margin="10,2,2,2"></TextBlock>
            <TextBlock Name="tb_2"  Margin="2"></TextBlock>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
            <TextBlock Text="壳体夹爪状态检测: " Margin="10,2,2,2"></TextBlock>
            <TextBlock Name="tb_3"  Margin="2"></TextBlock>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
            <TextBlock Text="PCB夹爪状态检测: " Margin="10,2,2,2"></TextBlock>
            <TextBlock Name="tb_4"  Margin="2"></TextBlock>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
            <TextBlock Text="后站联机: " Margin="10,2,2,2"></TextBlock>
            <TextBlock Name="tb_5"  Margin="2"></TextBlock>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
            <TextBlock Text="壳体工位是否启用: " Margin="10,2,2,2"></TextBlock>
            <TextBlock Name="tb_6"  Margin="2"></TextBlock>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
            <TextBlock Text="PCB工位是否启用: " Margin="10,2,2,2"></TextBlock>
            <TextBlock Name="tb_7"  Margin="2"></TextBlock>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
            <TextBlock Text="安全门: " Margin="10,2,2,2"></TextBlock>
            <TextBlock Name="tb_8"  Margin="2"></TextBlock>
        </StackPanel>
        <GroupBox Header="程控电源电流" Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2" HorizontalAlignment="Left">
                    <TextBlock Text="通道1: " Margin="10,0,0,0"></TextBlock>
                    <TextBlock Name="tb_Current1" Text="0" Width="60"  Background="White"></TextBlock>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="2" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="通道2: " Margin="10,0,0,0"></TextBlock>
                    <TextBlock Name="tb_Current2" Text="0" Width="60"  Background="White"></TextBlock>
                </StackPanel>
            </StackPanel>

        </GroupBox>
    </StackPanel>
   

</UserControl>
