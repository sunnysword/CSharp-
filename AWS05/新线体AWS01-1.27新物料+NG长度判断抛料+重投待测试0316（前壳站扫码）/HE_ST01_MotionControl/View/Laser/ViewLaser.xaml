<UserControl x:Class="Handler.View.Laser.ViewLaser"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Handler.View.Laser"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Margin="20" Orientation="Vertical" Width="200" HorizontalAlignment="Left"
                            DockPanel.Dock="Right">
            <TextBlock
                    Margin="5"
                    Background="Beige"
                    FontSize="20"
                    FontWeight="Bold"
                    Text="镭雕调试" />
            <TextBlock Margin="5" Text="产品条码" />
            <TextBox
                    x:Name="textBoxSN"
                    Width="200"
                    HorizontalAlignment="Left" />
            <Button
                    Margin="5"
                    HorizontalAlignment="Right"
                    Click="Button_Click"
                    Content="初始化模板" />

            <Button
                    Margin="5"
                    HorizontalAlignment="Right"
                    Click="Button_Click_1"
                    Content="数据发送" />

            <Button
                    Margin="5"
                    HorizontalAlignment="Right"
                    Click="Button_Click_2"
                    Content="开始打标" />

        </StackPanel>
    </Grid>
</UserControl>
