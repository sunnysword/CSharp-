<Window x:Class="Handler.View.DevManager.Wnd_DevLifeSetting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Handler.View.DevManager" xmlns:uc="clr-namespace:LanCustomControldll;assembly=LanCustomControldll"
        mc:Ignorable="d"
        Title="设备使用寿命设置" Height="400" Width="600" Loaded="Window_Loaded">
    <Grid>
        <Grid Background="DarkSeaGreen">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MaxHeight="60"></RowDefinition>
                <RowDefinition></RowDefinition>

            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="Auto" MinWidth="100" MaxWidth="130"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="0"  Content="(注：1s=1000ms)" VerticalAlignment="Center" FontSize="25" FontStyle="Italic"/>
                <!--<local:unit_SaveParamViewModel MaxHeight="40" x:Name="btn_SaveParam" Grid.Row="0" Grid.Column="1" />-->
                <uc:UC_SaveButton x:Name="btn_SaveParam"  Grid.Row="0" Grid.Column="1"  VerticalAlignment="Center" MaxHeight="40"></uc:UC_SaveButton>
            </Grid>


            <Grid  Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>

                    <ColumnDefinition></ColumnDefinition>

                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid Name="gd_Text_1" Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="Auto"></ColumnDefinition>

                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                </Grid>

            </Grid>

        </Grid>
    </Grid>
</Window>
