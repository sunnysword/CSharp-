<Window x:Class="Handler.View.Wnd_ProductMsg"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Handler.View"
        mc:Ignorable="d"
       Title="Detailed  production data" Height="350" Width="350" Loaded="Window_Loaded" Closed="Window_Closed" MaxWidth="350" MaxHeight="400">
    <Grid>
        <ListView Name="lv_Ng">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="150" DisplayMemberBinding="{Binding Name}">
                    </GridViewColumn>

                    <GridViewColumn Header="Number" Width="100" DisplayMemberBinding="{Binding Value}">
                    </GridViewColumn>

                </GridView>
            </ListView.View>



        </ListView>


    </Grid>
</Window>
