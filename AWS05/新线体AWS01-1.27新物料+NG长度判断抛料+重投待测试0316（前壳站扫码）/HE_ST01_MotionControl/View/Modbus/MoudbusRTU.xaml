<Window x:Class="Handler.View.MoudbusRTU.ModbusRTU"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Handler.View.MoudbusRTU"
        mc:Ignorable="d"
        Title="MoudbusRTU" Height="500" Width="800" Loaded="MoudbusRTU_Loaded" Closed="MoudbusRTU_Closed">
    <Grid Background="AliceBlue">
        <StackPanel Orientation="Vertical">
            <StackPanel Grid.Row="0" Width="400" HorizontalAlignment="Left" >
                <ComboBox Name="comb_FunctionCode" HorizontalAlignment="Left" Margin="65,15,0,0" VerticalAlignment="Top" Width="160" >
                </ComboBox>
                <Label Content="功能码:" Margin="10,-25,340,0"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Width="400" HorizontalAlignment="Right" >
                <Button  Name="btn_WriteRead" Content="读/写" HorizontalAlignment="Left" Margin="200,-18,0,0" VerticalAlignment="Top" Width="75" Click="Btn_Read_Write_Click"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Width="790" HorizontalAlignment="Left" >

                <GroupBox Header="地址信息" Name="GroupBoxRead" HorizontalAlignment="Left" Height="60" Margin="10,15,0,0" VerticalAlignment="Top" Width="761">
                    <StackPanel Orientation="Horizontal" Margin="0,5,5,2">
                        <Label Content="起始地址(十进制)：" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" />
                        <TextBox Name="tb_ReadStartAdress" Width="50" />
                        <Label Content="长度：" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top"/>
                        <TextBox Name="tb_ReadLength" Width="50"/>


                    </StackPanel>


                </GroupBox>



            </StackPanel>

            <StackPanel Grid.Row="3" Width="790" HorizontalAlignment="Left" >

                <GroupBox Header="写操作"  Name="GroupBoxWrite" HorizontalAlignment="Left" Height="60" Margin="10,15,0,0" VerticalAlignment="Top" Width="761">
                    <StackPanel Orientation="Horizontal" Margin="0,5,5,2">
                        <Label Content="写入内容：" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.875,-0.16"/>
                        <TextBox Name="tb_Date" Width="424"/>


                    </StackPanel>


                </GroupBox>



            </StackPanel>
            <!--<TextBox Name="tb_TextBox" HorizontalAlignment="Left" Height="151" Margin="10,10,0,0" Grid.Row="4" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="759"/>-->
            <GroupBox Grid.Row="4" Margin="5,5,22,10" Header="消息">
                <TextBox Name="tb_RichTextBox" HorizontalAlignment="Left" Height="100" Margin="10,10,0,0" VerticalAlignment="Top" Width="730">

                </TextBox>
            </GroupBox>
            <GroupBox Grid.Row="5" Margin="5,5,22,10" Header="扩展">
                <StackPanel Orientation="Horizontal" x:Name="stackPanel"/>
            </GroupBox>
        </StackPanel>


      

    </Grid>
</Window>
