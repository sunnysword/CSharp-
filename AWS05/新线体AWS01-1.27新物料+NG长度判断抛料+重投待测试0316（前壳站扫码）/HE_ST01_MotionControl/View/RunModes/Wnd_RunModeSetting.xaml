<Window
    x:Class="Handler.View.RunModes.Wnd_RunModeSetting"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Handler.View.RunModes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Mode selection"
    Width="600"
    Height="450"
    Closed="Window_Closed"
    Loaded="Window_Loaded"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel
            Grid.Row="0"
            Margin="20,20,20,10"
            Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="20"
                FontStyle="Italic"
                Text="Mode ：" />
            <ComboBox
                Name="cbb_RunModes"
                Width="200"
                FontSize="20"
                SelectionChanged="cbb_RunModes_SelectionChanged" />
        </StackPanel>
        <Grid Grid.Row="1" Margin="10,0,10,20">

            <ListBox x:Name="lb_Funs" FontSize="15">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />

                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Key}" />
                            <TextBlock Grid.Column="1" Text="=" />

                            <TextBlock Grid.Column="2" Text="{Binding Value}" />

                        </Grid>

                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

    </Grid>
</Window>
