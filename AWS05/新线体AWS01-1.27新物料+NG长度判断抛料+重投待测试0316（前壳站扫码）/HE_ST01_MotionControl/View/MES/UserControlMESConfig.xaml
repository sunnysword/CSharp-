<UserControl
    x:Class="FinalTestMachine.Views.UserControlMESConfig"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FinalTestMachine.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <DockPanel LastChildFill="True">
                <StackPanel Margin="20" Orientation="Vertical"
                            DockPanel.Dock="Right">
                    <TextBlock
                    Margin="5"
                    Background="Beige"
                    FontSize="20"
                    FontWeight="Bold"
                    Text="MES调试" />
                    <TextBlock Margin="5" Text="产品条码" />
                    <TextBox
                    x:Name="textBoxSN"
                    Width="200"
                    HorizontalAlignment="Left" />
                    <Button
                    x:Name="buttonSNCheck"
                    Margin="5"
                    HorizontalAlignment="Right"
                    Click="buttonSNCheck_Click"
                    Content="产品条码检查" />

                    <Button
                    Margin="5"
                    HorizontalAlignment="Right"
                    Click="btnMesUpload_Click"
                    Content="OK品过站" />

                    <Button
                    Margin="5"
                    HorizontalAlignment="Right"
                    Click="btnMesUploadNG_Click"
                    Content="NG品过站" />
                    <Button
                        Margin="5"
                    HorizontalAlignment="Right"
                    Click="btnMesBind_Click"
                    Content="SN-PCBSN绑定" >
                        
                    </Button>
                    
                   

                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <GroupBox Header="发送区">
                        <TextBox x:Name="tbx_Send"
                                 MinHeight="200"/>
                    </GroupBox>
                    <GroupBox Header="接收区">
                        <TextBox x:Name="tbx_Receive"
                                 MinHeight="200"/>
                    </GroupBox>
                </StackPanel>
            </DockPanel>
           
        </ScrollViewer>

    </Grid>

</UserControl>
