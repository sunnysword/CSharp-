                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <!--<Border Background="Gray" MaxHeight="40" MaxWidth="40" Margin="5"></Border>
                    <Border Background="Gray" Grid.Column="1" MaxHeight="40" MaxWidth="40" Margin="5"></Border>-->
                </Grid>

            </Viewbox>


        </Border>
    </Grid>
</UserControl>
