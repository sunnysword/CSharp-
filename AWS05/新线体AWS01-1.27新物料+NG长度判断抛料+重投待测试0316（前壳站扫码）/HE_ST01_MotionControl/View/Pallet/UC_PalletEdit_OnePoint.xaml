<UserControl x:Class="Handler.View.Pallet.UC_PalletEdit_OnePoint"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:LanCustomControldll="clr-namespace:LanCustomControldll;assembly=LanCustomControldll" xmlns:local1="clr-namespace:Handler.View.Pallet"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="800" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="200" ></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>

            </Grid.ColumnDefinitions>
            <GroupBox Header="维数设置" Margin="5,2" Name="gd_RowColSettings" IsEnabled="False">
                <StackPanel Orientation="Horizontal" Margin="8">
                    <TextBlock Text="行数 "></TextBlock>
                    <TextBox x:Name="tb_Dims_X" Width="80" IsEnabled="{Binding ElementName=gd_RowColSettings,Path=IsEnabled}"></TextBox>

                    <TextBlock Text="列数 " Margin="10,0"></TextBlock>
                    <TextBox x:Name="tb_Dims_Y" Width="80" IsEnabled="{Binding ElementName=gd_RowColSettings,Path=IsEnabled}"></TextBox>

                    <!--<TextBlock Text="Z轴标准点 " Margin="10,0"></TextBlock>
                    <LanCustomControldll:UC_TextBoxAndButton  x:Name="tb_Z_Standard" Grid.Row="2" Grid.Column="2"/>

                    <TextBlock Text="U轴标准点 " Margin="10,0"></TextBlock>
                    <LanCustomControldll:UC_TextBoxAndButton  x:Name="tb_U_Standard" Grid.Row="2" Grid.Column="3"/>-->

                    <!--<TextBox x:Name="tb_Z_Standard" Width="80" IsEnabled="{Binding ElementName=gd_RowColSettings,Path=IsEnabled}"></TextBox>-->
                </StackPanel>



            </GroupBox>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="btn_Edit" Content="编辑" VerticalAlignment="Top" Margin="0,10,5,0" Width="60" Height="35" Click="btn_Edit_Click"></Button>
                <Button x:Name="btn_Save" Content="Save"   VerticalAlignment="Top" Margin="0,10,5,0" Width="60" Height="35" Click="btn_Save_Click"></Button>

            </StackPanel>





        </Grid>

        <GroupBox Header="控制点" Grid.Row="1" IsEnabled="{Binding ElementName=gd_RowColSettings,Path=IsEnabled}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid Margin="20,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="5"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="10"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="10"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="10"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="10"></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="5"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="10"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="10"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="10"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition ></ColumnDefinition>

                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" Grid.Column="2" Text="X" FontSize="18" ></TextBlock>
                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" Grid.Column="4" Text="Y" FontSize="18" ></TextBlock>
                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" Grid.Column="6" Text="Z" FontSize="18" ></TextBlock>
                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" Grid.Column="8" Text="U" FontSize="18" ></TextBlock>

                    <TextBlock Text="视觉拍照位1" IsEnabled="{Binding ElementName=tb_Control_1_X,Path=IsEnabled}" Grid.Row="2" HorizontalAlignment="Right"></TextBlock>
                    <LanCustomControldll:UC_TextBoxAndButton  x:Name="tb_Control_1_X" Grid.Row="2" Grid.Column="2"/>
                    <LanCustomControldll:UC_TextBoxAndButton  x:Name="tb_Control_1_Y" IsEnabled="{Binding ElementName=tb_Control_1_X,Path=IsEnabled}" Grid.Row="2" Grid.Column="4"/>
                    <LanCustomControldll:UC_TextBoxAndButton  x:Name="tb_Control_1_Z" IsEnabled="{Binding ElementName=tb_Control_1_X,Path=IsEnabled}" Grid.Row="2" Grid.Column="6"/>
                    <LanCustomControldll:UC_TextBoxAndButton  x:Name="tb_Control_1_U" IsEnabled="{Binding ElementName=tb_Control_1_X,Path=IsEnabled}" Grid.Row="2" Grid.Column="8"/>


                   
                    
                    <TextBlock Text="行间距" IsEnabled="{Binding ElementName=tb_Control_2_X,Path=IsEnabled}" Grid.Row="4" HorizontalAlignment="Right"></TextBlock>
                    <TextBox x:Name="tb_RowSpacing" Grid.Row="4" Grid.Column="2"/>

                    <TextBlock Text="列间距" IsEnabled="{Binding ElementName=tb_Control_3_X,Path=IsEnabled}" Grid.Row="6" HorizontalAlignment="Right"></TextBlock>
                    <TextBox  x:Name="tb_ColumnSpacing" Grid.Row="6" Grid.Column="2"/>

                    <TextBlock Text="固定夹取位1" IsEnabled="{Binding ElementName=tb_Control_1_X,Path=IsEnabled}" Grid.Row="8" HorizontalAlignment="Right"></TextBlock>
                    <LanCustomControldll:UC_TextBoxAndButton  x:Name="tb_Control_2_X" Grid.Row="8" Grid.Column="2"/>
                    <LanCustomControldll:UC_TextBoxAndButton  x:Name="tb_Control_2_Y" IsEnabled="{Binding ElementName=tb_Control_1_X,Path=IsEnabled}" Grid.Row="8" Grid.Column="4"/>
                    <LanCustomControldll:UC_TextBoxAndButton  x:Name="tb_Control_2_Z" IsEnabled="{Binding ElementName=tb_Control_1_X,Path=IsEnabled}" Grid.Row="8" Grid.Column="6"/>
                    <LanCustomControldll:UC_TextBoxAndButton  x:Name="tb_Control_2_U" IsEnabled="{Binding ElementName=tb_Control_1_X,Path=IsEnabled}" Grid.Row="8" Grid.Column="8"/>

                    <!--<TextBlock Text="控制点4" IsEnabled="{Binding ElementName=tb_Control_4_X,Path=IsEnabled}" Grid.Row="8" HorizontalAlignment="Right"></TextBlock>
                    <LanCustomControldll:UC_TextBoxAndButton  x:Name="tb_Control_4_X" Grid.Row="8" Grid.Column="2"/>
                    <LanCustomControldll:UC_TextBoxAndButton  x:Name="tb_Control_4_Y" IsEnabled="{Binding ElementName=tb_Control_4_X,Path=IsEnabled}" Grid.Row="8" Grid.Column="4"/>-->

                </Grid>
                <Grid x:Name="gd_1" Margin="20" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                </Grid>
                <!--<Image x:Name="img_ControlPoint_Tip" Margin="5" Width="200"  Stretch="Fill" Grid.Column="1"  Source="/Resources/Point_3.jpg"/>-->
                
                <Border Grid.Column="2"  MinWidth="100">

                </Border>
                <Button Content="生成阵列点" Name="btn_GenPalletPoints" IsEnabled="{Binding ElementName=gd_RowColSettings,Path=IsEnabled}"  Height="30"  Grid.Column="3" FontSize="10" VerticalAlignment="Top" Click="btn_GenPalletPoints_Click"></Button>




            </Grid>

        </GroupBox>

        <Grid Grid.Row="3" Margin="10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition Width="Auto" MinWidth="150"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <TabControl Background="Transparent">
                <TabItem Header="图形" Width="80">
                    <local1:UC_Pallet_Box x:Name="uc_Boxs"   ></local1:UC_Pallet_Box>
                </TabItem>
                <TabItem Header="点位信息" Width="80">
                    <DataGrid Name="Dg_Msg"  IsReadOnly="True"  Margin="1" FontSize="15" AutoGenerateColumns="False" RowHeight="25" >
                        <DataGrid.Columns>
                            <DataGridTextColumn  Header="编号"  Width="60"  CanUserSort="False"  Binding="{Binding Id}"  IsReadOnly="True" >
                            </DataGridTextColumn>
                            <DataGridTextColumn  Header="X"  Width="100" CanUserSort="False"  Binding="{Binding X}"  IsReadOnly="True" >
                            </DataGridTextColumn>
                            <DataGridTextColumn  Header="Y"  Width="100" CanUserSort="False"  Binding="{Binding Y}"  IsReadOnly="True" >
                            </DataGridTextColumn>
                            <DataGridTextColumn  Header="Z"  Width="100" CanUserSort="False"  Binding="{Binding Z}"  IsReadOnly="True" >
                            </DataGridTextColumn>
                            <DataGridTextColumn  Header="U"  Width="100" CanUserSort="False"  Binding="{Binding U}"  IsReadOnly="True" >
                            </DataGridTextColumn>



                        </DataGrid.Columns>


                    </DataGrid>

                </TabItem>
            </TabControl>

            <StackPanel Grid.Column="1" Margin="10,40">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock  Text="当前点编号:"></TextBlock>
                    <TextBox x:Name="tb_PointIndex" Text="0" Margin="5,0" Width="40" VerticalContentAlignment="Center"></TextBox>
                </StackPanel>

                <Button Content="下一点" Width="80" Height="30" Name="btn_Next" Margin="0,5" Click="btn_Next_Click"></Button>

                <Button Content="上一点" Width="80" Height="30" Name="btn_Up" Margin="0,5" Click="btn_Up_Click"></Button>

                <Button Content="起始点" Width="80" Height="30" Name="btn_FirstPoint" Margin="0,5" Click="btn_FirstPoint_Click"></Button>
                <Button Content="最后一点" Width="80" Height="30" Name="btn_LastPoint" Margin="0,5" Click="btn_LastPoint_Click"></Button>
                <Button Content="Z轴下降" Width="80" Height="30" Name="btn_ZDown" Margin="0,5" Click="btn_ZDown_Click"></Button>
                <StackPanel Visibility="Collapsed" Orientation="Horizontal" Margin="0,0,0,0">
                    <TextBlock  Text="夹持距离:"></TextBlock>
                    <TextBox x:Name="txtClampDistance" Text="200" Margin="5,0" Width="50" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"></TextBox>
                </StackPanel>
                <Button Content="夹爪加紧" Width="80" Height="30" Name="btn_Clamp" Margin="0,5" Click="btn_Clamp_Click"></Button>
                <Button Content="夹爪松开" Width="80" Height="30" Name="btn_Clamp2" Margin="0,5" Click="btn_Clamp_Click2"></Button>
                <Button Content="Z轴上升" Width="80" Height="30" Name="btn_ZUp" Margin="0,5" Click="btn_ZUp_Click"></Button>
                <Button Content="停止" Width="80" Height="30" Name="btn_Stop" Margin="0,5" Click="btn_Stop_Click"></Button>

                <!--<Button Content="自动拍照取料" Width="80" Height="30" Name="btn_AutoCamTake" Margin="0,5" Click="btn_AutoCamTake_Click"></Button>-->
            </StackPanel>

        </Grid>



    </Grid>
</UserControl>
